    "@types/jest": "30.0.0",
    "@types/node": "25.6.0",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "@typhonjs-fvtt/eslint-config-foundry.js": "0.8.0",
    "babel-jest": "30.3.0",
    "esbuild": "0.28.0",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "handlebars": "4.7.9",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "jest-junit": "17.0.0",
    "jquery": "4.0.0",
    "jshint": "2.13.6",
    "prettier": "3.8.3",
    "ts-jest": "29.4.9",
    "typescript": "6.0.3"
